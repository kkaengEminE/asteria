---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({ params: { slug: article.id }, props: { article } }));
}

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { Content } = await render(article);
---

<BaseLayout
  title={article.data.title}
  description={article.data.description}
  canonicalPath={`/articles/${article.id}/`}
>
  <article class="article-detail">
    <header>
      <a class="category-link" href={`/categories/${article.data.category}/`}>{article.data.categoryLabel}</a>
      <h1>{article.data.title}</h1>
      <p class="article-dek">{article.data.description}</p>
    </header>
    <div class="article-body">
      <Content />
    </div>
  </article>
</BaseLayout>
